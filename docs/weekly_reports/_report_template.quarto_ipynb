      "source": [
        "#| label: fig-tie-map\n",
        "#| fig-cap: 'Tie geocoding pairs. Each color represents one address; filled and hollow circles mark the two candidate coordinates, connected by a line. Distance (km) is labeled at the midpoint.'\n",
        "#| echo: false\n",
        "#| warning: false\n",
